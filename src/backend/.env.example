NODE_ENV=development
PORT=3000

# URL de conexão do MongoDB. Exemplo local:
# MONGODB_URI=mongodb://127.0.0.1:27017/vaptfood
MONGODB_URI=

# Chave usada para assinar tokens JWT. Troque por um valor forte em produção.
JWT_SECRET=troque-esta-chave
JWT_EXPIRES_IN=1d

# Origem permitida para chamadas do frontend/mobile. Use "*" em desenvolvimento.
CORS_ORIGIN=*

# Chave secreta da Stripe, quando o fluxo de pagamento for integrado.
STRIPE_SECRET_KEY=
